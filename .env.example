# GIS MCP runtime transport configuration
GIS_MCP_TRANSPORT=http
GIS_MCP_HOST=0.0.0.0
GIS_MCP_PORT=8080

# Optional: local storage path override
# GIS_MCP_STORAGE_PATH=/absolute/path/to/storage

# Orchestrator registration controls
MCP_REGISTRATION_ENABLED=true
MCP_REGISTRATION_SECRET=replace-with-shared-secret
MCP_SERVER_ID=gis_mcp
MCP_DESCRIPTION=GIS MCP server

# Prefer a full base URL if available
# ORCHESTRATOR_BASE_URL=http://127.0.0.1:8000

# Or provide orchestrator host/port and the server builds the URL
ORCHESTRATOR_IP=127.0.0.1
ORCHESTRATOR_PORT=8000

# Publicly reachable base URL for this MCP server (recommended when host=0.0.0.0)
MCP_BASE_URL=http://127.0.0.1:8080
